{
  "name": "subject-identifiers",
  "version": "1.0.2",
  "description": "Typescript implementation of RFC 9493 Subject Identifiers for Security Event Tokens",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project ./tsconfig.build.json",
    "clean": "tsc --build --clean ./tsconfig.build.json && rm -rf ./dist",
    "test": "node --test --test-reporter=${REPORTER:-@reporters/mocha} --import tsx $(find test -type f -name '*.test.ts')",
    "test:gh": "REPORTER=@reporters/gh npm run test",
    "test:ci": "c8 --reporter=lcov --reporter=text npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdkitzman/subject-identifiers.git"
  },
  "keywords": [
    "rfc9493",
    "subject",
    "identifiers",
    "typescript",
    "node"
  ],
  "author": "Mike Kitzman",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mdkitzman/subject-identifiers/issues"
  },
  "homepage": "https://github.com/mdkitzman/subject-identifiers#readme",
  "devDependencies": {
    "@reporters/gh": "^1.3.0",
    "@reporters/mocha": "^1.2.0",
    "@types/node": "^24.0.8",
    "c8": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2"
  }
}
